import os
import re
import sys
import subprocess

# 系统配置

DNA_REGISTRY = "SIFU_DNA.md"
DNA_EXT = ".dna"
CODE_EXTS = ('.py', '.js', '.go', '.ts', '.rs')

def get_staged_files():
    """获取暂存区文件列表"""
    cmd = ["git", "diff", "--cached", "--name-only"]
    return subprocess.check_output(cmd).decode('utf-8').splitlines()

def check_no_deletion(filepath):
    """确保 DNA 文件只准追加，不准删除（遗传信息的稳定性）"""
    diff = subprocess.check_output(["git", "diff", "--cached", filepath]).decode('utf-8')
    for line in diff.splitlines():
        # 如果有以 - 开头且不是 diff 标记的行，说明有删除
        if line.startswith("-") and not line.startswith("---") and line[1:].strip():
            print(f"CRITICAL: Deletion detected in DNA file {filepath}.")
            print("Sifu says: Inheritance cannot be erased. Use 'DEPRECATED' instead of deleting.")
            sys.exit(1)

def main():
    staged = get_staged_files()
    if not staged: return

    # 1. 验证全局 DNA 注册表
    if DNA_REGISTRY in staged:
        check_no_deletion(DNA_REGISTRY)
    
    # 读取当前全局 DNA ID 库
    with open(DNA_REGISTRY, 'r', encoding='utf-8') as f:
        content = f.read()
    valid_ids = set(re.findall(r"\[DNA-(\d+)\]", content))
    
    # 2. 验证代码文件与 DNA 侧边文件的关联
    for f in staged:
        if any(f.endswith(ext) for ext in CODE_EXTS):
            dna_file = f + DNA_EXT
            
            # A. 必须有对应的 DNA 文件
            if dna_file not in staged:
                print(f"ERROR: Code file '{f}' lacks a corresponding '{dna_file}'.")
                sys.exit(1)
            
            # B. DNA 文件不准有删除操作
            check_no_deletion(dna_file)
            
            # C. 检查 DNA 文件是否引用了全局 ID
            dna_diff = subprocess.check_output(["git", "diff", "--cached", dna_file]).decode('utf-8')
            new_refs = re.findall(r"\+.*\[DNA-(\d+)\]", dna_diff)
            
            if not new_refs:
                print(f"ERROR: New entries in '{dna_file}' must reference a [DNA-ID].")
                sys.exit(1)
            
            for ref in new_refs:
                if ref not in valid_ids:
                    print(f"ERROR: Invalid DNA-ID '{ref}' in '{dna_file}'. Register it in {DNA_REGISTRY} first.")
                    sys.exit(1)
    
    print("SUCCESS: DNA integrity verified. Practice (Code) approved.")

if __name__ == "__main__":
    main()



