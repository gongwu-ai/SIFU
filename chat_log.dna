import os
import re
import sys
import subprocess

# 师傅的戒条
DNA_REGISTRY = "SIFU_DNA.md"
DNA_EXT = ".dna"
CODE_EXTS = ('.py', '.js', '.go', '.ts', '.rs', '.cpp')

def get_staged_files():
    """获取暂存区文件列表"""
    try:
        cmd = ["git", "diff", "--cached", "--name-only"]
        return subprocess.check_output(cmd).decode('utf-8').splitlines()
    except Exception:
        return []

def check_no_deletion(filepath):
    """确保 DNA 文件只准追加，不准删除（遗传信息的稳定性）"""
    diff = subprocess.check_output(["git", "diff", "--cached", filepath]).decode('utf-8')
    # 查找是否有减号开头的行，且不是 diff 自身的元数据
    deleted_lines = [l for l in diff.splitlines() if l.startswith("-") and not l.startswith("---") and l[1:].strip()]
    if deleted_lines:
        print(f"❌ Sifu Error: DNA 序列不可磨灭 ({filepath})。")
        print(f"   删除内容示例: {deleted_lines[0][:50]}")
        print("   师傅教诲：过往不可追，如需废弃请使用 'DEPRECATED' 关键字。")
        sys.exit(1)

def main():
    staged = get_staged_files()
    if not staged:
        return

    # 1. 验证全局 DNA 注册表是否存在
    if not os.path.exists(DNA_REGISTRY):
        print(f"❌ Sifu Error: 找不到全局 DNA 注册表 {DNA_REGISTRY}。")
        sys.exit(1)

    # 2. 如果注册表在本次提交中，检查是否有删除
    if DNA_REGISTRY in staged:
        check_no_deletion(DNA_REGISTRY)
    
    # 3. 预加载所有有效的 DNA ID
    with open(DNA_REGISTRY, 'r', encoding='utf-8') as f:
        content = f.read()
    # 匹配 [DNA-101] 这种格式
    valid_ids = set(re.findall(r"\[DNA-(\d+)\]", content))
    
    # 4. 检查每个代码文件
    for f in staged:
        if any(f.endswith(ext) for ext in CODE_EXTS):
            dna_file = f + DNA_EXT
            
            # A. 强制关联检查
            if dna_file not in staged and not os.path.exists(dna_file):
                print(f"❌ Sifu Error: 代码 '{f}' 缺乏灵魂（找不到对应的 {dna_file}）。")
                sys.exit(1)
            
            # B. 遗传稳定性检查
            if dna_file in staged:
                check_no_deletion(dna_file)
                
                # C. 意图引用检查
                dna_diff = subprocess.check_output(["git", "diff", "--cached", dna_file]).decode('utf-8')
                new_refs = re.findall(r"\+.*\[DNA-(\d+)\]", dna_diff)
                
                if not new_refs:
                    print(f"❌ Sifu Error: '{dna_file}' 的新记录必须引用一个全局 [DNA-ID]。")
                    sys.exit(1)
                
                for ref in new_refs:
                    if ref not in valid_ids:
                        print(f"❌ Sifu Error: '{dna_file}' 引用了未注册的 ID [DNA-{ref}]。请先更新 {DNA_REGISTRY}。")
                        sys.exit(1)
    
    print("✅ Sifu: DNA 完整，修行合规。")

if __name__ == "__main__":
    main()



### 4. 为什么这个系统够「理智」？

1.  **容错性**：AI Agent 采样代码采错了没关系，删了重采样就好，因为代码只是「表现型」。只要 `.dna` 文件没写错，系统的**「本质」**就不会丢失。
2.  **追溯力**：如果你问“为什么要写这个函数？”，你不需要去翻代码里的注视，直接看 `main.py.dna` 里的 `[DNA-ID]`。它是按照时间线递增的，清清楚楚。
3.  **硬盘空间的权衡**：你放弃了硬盘，换取了**系统的「不死性」**。在 Agentic 时代，这笔买卖非常划算。
4.  **师傅的尊严**：`Sifu` 这个名字不仅是江湖味，它代表了**“由人（师傅）把控设计，由 Agent（徒弟）去修行”**的权力结构。

**这套系统最理智的一点在于：它承认了代码是低价值的采样，而人类的决策意图（DNA）才是高价值的资产。**

你准备好在你的 `Sifu` 项目里开始第一次「注册 DNA」了吗？